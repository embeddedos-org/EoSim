# ============================================================================
# EoSim — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Production defaults are pre-configured. Override only what you need.
# ============================================================================

# ── Environment ──────────────────────────────────────────────────────────────
# Options: production | development | staging
EOSIM_ENV=production

# ── API Server ───────────────────────────────────────────────────────────────
EOSIM_HOST=0.0.0.0
EOSIM_PORT=8080
EOSIM_WORKERS=4
EOSIM_LOG_LEVEL=INFO

# ── Production Endpoints (do not change for production) ──────────────────────
EOSIM_API_URL=https://api.eosim.io
EOSIM_WS_URL=wss://api.eosim.io
EOSIM_DOCS_URL=https://docs.eosim.io
EOSIM_STATUS_URL=https://status.eosim.io
EOSIM_CDN_URL=https://cdn.eosim.io
EOSIM_AUTH_URL=https://auth.eosim.io
EOSIM_METRICS_URL=https://metrics.eosim.io

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
EOSIM_SECRET_KEY=change-me-to-a-random-64-char-hex-string
EOSIM_API_KEY=your-api-key-here
EOSIM_JWT_ALGORITHM=HS256
EOSIM_JWT_EXPIRE_MINUTES=60

# ── Database (optional — for persistent simulation state) ────────────────────
# EOSIM_DB_URL=postgresql://user:password@db-host:5432/eosim
# EOSIM_DB_POOL_SIZE=10
# EOSIM_DB_MAX_OVERFLOW=20

# ── Redis (optional — for caching and pub/sub) ────────────────────────────────
# EOSIM_REDIS_URL=redis://redis-host:6379/0

# ── Storage ──────────────────────────────────────────────────────────────────
EOSIM_DATA_DIR=/opt/eosim/data
EOSIM_OUTPUT_DIR=/opt/eosim/out
EOSIM_PLATFORMS_DIR=/opt/eosim/platforms

# ── QEMU / Simulation Engines ─────────────────────────────────────────────────
# EOSIM_QEMU_BIN=/usr/bin/qemu-system-arm
# EOSIM_RENODE_BIN=/opt/renode/renode
# EOSIM_TIMEOUT=300

# ── Internationalization ──────────────────────────────────────────────────────
# Default language (en|es|zh|hi|fr|ar|pt|de|ja|ko)
EOSIM_LANG=en

# ── Telemetry (opt-in) ────────────────────────────────────────────────────────
# EOSIM_TELEMETRY=false
# EOSIM_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ── TLS / HTTPS (for direct TLS termination) ─────────────────────────────────
# EOSIM_TLS_CERT=/etc/ssl/certs/eosim.crt
# EOSIM_TLS_KEY=/etc/ssl/private/eosim.key

# ── Docker / Kubernetes ───────────────────────────────────────────────────────
# EOSIM_IMAGE=ghcr.io/embeddedos-org/eosim:3.0.1
# EOSIM_REGISTRY=ghcr.io/embeddedos-org
